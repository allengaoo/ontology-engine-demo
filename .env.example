# ============================================================
# ontology-engine-demo Phase 2 环境变量配置模板
# 复制此文件为 .env 并填入真实值：
#   cp .env.example .env
# ============================================================

# ── LLM 配置（必填才能走真实 LLM；不填则自动 fallback 到 mock） ──

# API 密钥（必填）
# OpenAI:   sk-...
# DeepSeek: sk-...
# 其他兼容接口按其文档填写
LLM_API_KEY=

# API 接口地址（可选，默认 OpenAI 官方）
# OpenAI 官方（默认，可不填）: https://api.openai.com/v1
# DeepSeek:                    https://api.deepseek.com/v1
# Azure OpenAI:                https://<your-resource>.openai.azure.com/openai/deployments/<model>
LLM_BASE_URL=

# 模型名称（可选，默认 gpt-4o-mini）
# OpenAI:   gpt-4o-mini / gpt-4o / gpt-4-turbo
# DeepSeek: deepseek-chat / deepseek-coder
# 其他按供应商文档填写
LLM_MODEL=
